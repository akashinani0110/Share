<!DOCTYPE html><html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Slide Template</title>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; margin: 0; padding: 0; background-color: #f8f8f8; }
        .slide { width: 80%; margin: auto; padding: 20px; background: white; box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1); text-align: left; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ddd; padding-bottom: 10px; }
        .title { font-size: 1.8em; font-weight: bold; }
        .subtitle { font-size: 1.2em; color: gray; }
        .content { margin: 20px 0; font-size: 1em; }
        .formula { font-family: "Times New Roman", Times, serif; font-size: 1.2em; }
        .footer { text-align: left; font-size: 0.8em; color: darkgray; border-top: 2px solid #ddd; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="slide">
        <div class="header">
            <div class="title">{{title}}</div>
            <img src="logo.png" alt="Logo" height="40">
        </div>
        <div class="subtitle">{{subtitle}}</div>
        <div class="content">{{body}}</div>
        <div class="footer">{{footer}}</div>
    </div>
</body>
</html>