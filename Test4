library(shiny)

ui <- fluidPage(
  titlePanel("Dashboard Updates"),
  dataTableOutput("dashboard_table")
)

server <- function(input, output) {
  
  output$dashboard_table <- renderDataTable({
    
    # calculate the number of days since last update
    dashboard_data$days_since_last_update <- as.numeric(difftime(Sys.Date(), dashboard_data$last_updated_on, units = "days"))
    
    # calculate whether the update is overdue or not
    dashboard_data$update_overdue <- ifelse(dashboard_data$required_update_in_days < dashboard_data$days_since_last_update, "yes", "no")
    
    # color the rows based on whether the update is overdue or not
    dashboard_color <- ifelse(dashboard_data$update_overdue == "yes", "red", "green")
    
    # create the data table
    datatable(
      dashboard_data,
      options = list(
        columnDefs = list(list(targets = "_all", className = "dt-center")),
        pageLength = 10,
        lengthMenu = c(10, 25, 50),
        autoWidth = TRUE
      ),
      rownames = FALSE,
      class = "cell-border stripe",
      rowCallback = JS(paste0("
        function(row, data) {
          $('td', row).css('background-color', '", dashboard_color, "');
        }
      "))
    )
    
  })
  
}

shinyApp(ui, server)

