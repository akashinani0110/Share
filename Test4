library(shiny)
library(dplyr)

# Read the data from a CSV file
data <- read.csv("data.csv", stringsAsFactors = FALSE)

# Define the UI for the Shiny app
ui <- fluidPage(
  titlePanel("Dashboard"),
  dataTableOutput("dashboard_table")
)

# Define the server for the Shiny app
server <- function(input, output) {
  output$dashboard_table <- renderDataTable({
    # Create a new column for the required update in days
    data <- data %>% mutate(required_update_in_days = as.numeric(difftime(Sys.Date(), last_updated_on, units = "days")))
    
    # Create a new column for the color
    data <- data %>% mutate(color = ifelse(required_update_in_days > (Sys.Date() - last_updated_on), "red", "green"))
    
    # Return the data table with the color formatting
    datatable(data, options = list(pageLength = 10), rownames = FALSE) %>%
      formatStyle("color", backgroundColor = styleEqual(c("green", "red"), c("green", "red")))
  })
}

# Run the Shiny app
shinyApp(ui = ui, server = server)



