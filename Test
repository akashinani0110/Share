library(shiny)
library(rvest)

# Define function to search for keyword in site content
find_last_modified <- function(site_url, keyword) {
  # Use rvest to scrape site content
  site_content <- read_html(site_url)
  
  # Search for keyword in site content
  keyword_matches <- grep(keyword, site_content, ignore.case = TRUE)
  
  # If keyword is found, extract date and content
  if(length(keyword_matches) > 0) {
    last_modified_date <- date()
    last_modified_content <- site_content[keyword_matches]
    return(list(date = last_modified_date, content = last_modified_content))
  } else {
    return(NULL)
  }
}

# Define Shiny UI
ui <- fluidPage(
  sidebarLayout(
    sidebarPanel(
      textInput("keyword", "Keyword to search for:", ""),
      textInput("site1_url", "Site 1 URL:", ""),
      textInput("site2_url", "Site 2 URL:", ""),
      textInput("site3_url", "Site 3 URL:", "")
    ),
    mainPanel(
      verbatimTextOutput("results")
    )
  )
)

# Define Shiny server
server <- function(input, output) {
  # Define function to search for last modified content for each site
  search_sites <- function() {
    results <- list()
    if(input$site1_url != "") {
      results$site1 <- find_last_modified(input$site1_url, input$keyword)
    }
    if(input$site2_url != "") {
      results$site2 <- find_last_modified(input$site2_url, input$keyword)
    }
    if(input$site3_url != "") {
      results$site3 <- find_last_modified(input$site3_url, input$keyword)
    }
    return(results)
  }
  
  # Update results output when user submits form
  output$results <- renderPrint({
    search_sites()
  })
}

# Run Shiny app
shinyApp(ui, server)
