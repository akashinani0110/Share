library(rvest)

fetch_div_content <- function(site_url, div_id) {
  
  # Fetch the HTML content of the website
  site_content <- read_html(site_url)
  
  # Find the <div> element by its ID using XPath
  div_element <- site_content %>%
    html_node(xpath = paste0('//*[@id="', div_id, '"]'))
  
  # Extract the content of the <div> element as plain text
  div_content <- html_text(div_element)
  
  # Return the content of the <div> element
  return(div_content)
}
